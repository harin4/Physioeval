# PhysioEval Enhanced — Environment Variables
# Copy this file to .env and fill in your values

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false

# ── AWS Credentials ───────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=us-east-1

# ── S3 ────────────────────────────────────────────────────────────────────────
S3_BUCKET_NAME=physio-eval-uploads

# ── DynamoDB ──────────────────────────────────────────────────────────────────
DYNAMODB_TABLE_NAME=physio-eval-results

# ── Lambda / SQS (for event-driven pipeline) ──────────────────────────────────
LAMBDA_ROLE_ARN=arn:aws:iam::YOUR_ACCOUNT_ID:role/physio-eval-lambda-role
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/physio-eval-queue
PHYSIO_API_URL=https://your-deployed-api.com

# ── Local Storage Fallback (set to true for local dev without AWS) ─────────────
USE_LOCAL_STORAGE=true
LOCAL_UPLOAD_DIR=./uploads
LOCAL_RESULTS_DIR=./results

# ── Gradio ────────────────────────────────────────────────────────────────────
GRADIO_PORT=7860
